# Copy to ".env" and fill in. Generate the first two with:  python -m app.auth
# (run it locally in the project venv; it never transmits your password).

# PBKDF2 hash of your edit password. If unset, EDITING IS DISABLED and the app runs as
# a read-only public calculator (fail-safe) — set this to enable editing.
OWNER_PASSWORD_HASH=

# Local dev only: allow the built-in default password ("sweetspot") when no hash is set.
# NEVER set this on a public deploy (the password is in the public source).
ALLOW_DEFAULT_PASSWORD=

# Random secret that signs the login session cookie. Always set this in production.
SWEETSPOT_SECRET=

# Expose the interactive API docs (/docs, /redoc, /openapi.json). Off by default.
ENABLE_DOCS=

# Served behind HTTPS (Nginx Proxy Manager) → keep the session cookie Secure.
COOKIE_SECURE=1

# The docker network Nginx Proxy Manager is attached to (see: docker network ls).
PROXY_NETWORK=npm_default

# Published host port (host:container 8000). Reach the app at http://<host>:APP_PORT.
APP_PORT=8082

# Image tag to run from GHCR. "latest" = newest main build; pin a commit SHA to roll back.
IMAGE_TAG=latest
